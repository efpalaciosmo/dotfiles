# macOS Brewfile.
# Optimized for CLI development, Neovim, LaTeX/math writing, data work,
# and dotfile automation.

# =============================================================================
# 1. Bootstrap essentials
# =============================================================================
# Keep this section small: tools needed early by dotfiles, scripts, shells,
# and the rest of the setup.

brew "git"
brew "gh"
brew "curl"
brew "wget"
brew "make"
brew "stow"
brew "python"
brew "unzip"
brew "xz"
brew "sevenzip"
brew "bash"
brew "bash-completion@2"
brew "zsh"
brew "starship"
brew "jq"


# =============================================================================
# 2. GNU compatibility
# =============================================================================
# macOS ships BSD variants of many tools. These GNU versions keep shell scripts
# and Neovim helpers predictable.

brew "coreutils"
brew "findutils"
brew "gnu-tar"
brew "gnu-sed"
brew "grep"
brew "gawk"


# =============================================================================
# 3. Build tools
# =============================================================================

brew "cmake"
brew "ninja"
brew "pkgconf"


# =============================================================================
# 4. Daily CLI tools
# =============================================================================

brew "tree"
brew "fd"
brew "ripgrep"
brew "fzf"
brew "bat"
brew "btop"
brew "tmux"
brew "zoxide"
brew "duf"
brew "ncdu"
brew "fastfetch"
brew "lazygit"
brew "harlequin"
brew "lazydocker"
brew "yazi"
brew "resvg"


# =============================================================================
# 5. Shell / script quality tools
# =============================================================================
# Very useful for dotfiles, automation scripts, CI scripts and Brew-managed setup.

brew "shellcheck"
brew "shfmt"


# =============================================================================
# 6. Editor tooling
# =============================================================================

brew "neovim"
brew "tree-sitter-cli"
brew "lua"
brew "stylua"

# =============================================================================
# 7. LaTeX / thesis writing
# =============================================================================
# Full TeX Live distribution without GUI apps. Good fit for terminal/Neovim.
cask "mactex-no-gui"


# =============================================================================
# 8. Language/package managers
# =============================================================================

brew "uv"
brew "fnm"
brew "node"
brew "pnpm"


# =============================================================================
# 9. Programming languages / heavier toolchains
# =============================================================================

brew "zig"
brew "juliaup"
brew "llvm"


# =============================================================================
# 10. Data, documents, PDFs, images and media
# =============================================================================
# poppler: PDF tools, pdftotext, pdfinfo, etc.
# imagemagick-full: broader image format support than imagemagick.
# ffmpeg-full: broader codec/library support than ffmpeg.

brew "poppler"
brew "imagemagick-full"
brew "ffmpeg-full"
