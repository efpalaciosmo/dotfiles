border-color=#36363a
progress-color=#9a9996
default-timeout=5000

[urgency=high]
text-color=#ffffff
border-color=#ed333b
progress-color=#ff7800
default-timeout=0

[app-name=volume]
border-color=#2ec27e
progress-color=#2ec27e

[app-name=Spotify]
border-color=#2ec27e
progress-color=#2ec27e
