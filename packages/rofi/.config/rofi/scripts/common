#!/usr/bin/env bash

menu() {
    local prompt=$1
    shift

    if command -v rofi >/dev/null 2>&1; then
        printf '%s\n' "$@" | rofi -dmenu -i -p "$prompt" -matching fuzzy
    elif command -v fuzzel >/dev/null 2>&1; then
        printf '%s\n' "$@" | fuzzel --dmenu --prompt "$prompt"
    elif command -v wofi >/dev/null 2>&1; then
        printf '%s\n' "$@" | wofi --dmenu --prompt "$prompt"
    else
        return 1
    fi
}

notify_user() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "$@" || true
    fi
    return 0
}

missing_commands() {
    local missing=() cmd
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
    done

    ((${#missing[@]} == 0)) && return 0
    notify_user "Missing command" "${missing[*]}"
    printf 'Missing command(s): %s\n' "${missing[*]}" >&2
    return 1
}
