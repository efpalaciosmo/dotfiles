{
  "Inline math": {
    "prefix": "mt",
    "body": "\\$${1:expr}\\$ ",
    "description": "Inline math"
  },
  "Display math": {
    "prefix": "mmt",
    "body": [
      "\\$",
      "  ${1:expr}",
      "\\$"
    ],
    "description": "Display math"
  },
  "Centered block": {
    "prefix": "cent",
    "body": "#align(center)[${1:content}]",
    "description": "Centered content"
  },
  "Let binding": {
    "prefix": "v",
    "body": "#let ${1:name} = ${2:value}",
    "description": "Typst let binding"
  },
  "Function binding": {
    "prefix": "f",
    "body": [
      "#let ${1:name}(${2:args}) = {",
      "  ${3:body}",
      "}"
    ],
    "description": "Typst function binding"
  },
  "Theorem": {
    "prefix": "thm",
    "body": [
      "#theorem(\"${1:Title}\")[",
      "  ${2:statement}",
      "]"
    ],
    "description": "Theorem block"
  },
  "Definition": {
    "prefix": "defn",
    "body": [
      "#definition(\"${1:Title}\")[",
      "  ${2:definition}",
      "]"
    ],
    "description": "Definition block"
  },
  "Proof": {
    "prefix": "proof",
    "body": [
      "#proof[",
      "  ${1:argument}",
      "]"
    ],
    "description": "Proof block"
  },
  "Chapter": {
    "prefix": "chap",
    "body": "= ${1:Chapter Title}",
    "description": "Book chapter heading"
  },
  "Section": {
    "prefix": "sec",
    "body": "== ${1:Section Title}",
    "description": "Section heading"
  }
}
