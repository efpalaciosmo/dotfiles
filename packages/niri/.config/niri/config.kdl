// ~/.config/niri/config.kdl
// Configuracion principal modular para Niri.
// Copia este archivo como: ~/.config/niri/config.kdl

// Los include deben estar en el nivel superior del archivo.
include "autostart.kdl"
include "keyboard.kdl"
include "environment.kdl"
include "input.kdl"
include "appearance.kdl"
include "layout.kdl"
include "rules.kdl"
include "debug.kdl"
include "monitors.kdl"

prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

