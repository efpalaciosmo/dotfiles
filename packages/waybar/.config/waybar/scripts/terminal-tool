#!/usr/bin/env bash
set -euo pipefail

exec_term() {
    if command -v foot >/dev/null 2>&1; then
        exec foot -e "$@"
    elif command -v alacritty >/dev/null 2>&1; then
        exec alacritty -e "$@"
    elif command -v kitty >/dev/null 2>&1; then
        exec kitty "$@"
    elif command -v ghostty >/dev/null 2>&1; then
        exec ghostty -e "$@"
    elif command -v wezterm >/dev/null 2>&1; then
        exec wezterm start -- "$@"
    elif command -v xdg-terminal-exec >/dev/null 2>&1; then
        exec xdg-terminal-exec "$@"
    elif command -v ptyxis >/dev/null 2>&1; then
        exec ptyxis -- "$@"
    elif command -v kgx >/dev/null 2>&1; then
        exec kgx -- "$@"
    elif command -v gnome-terminal >/dev/null 2>&1; then
        exec gnome-terminal -- "$@"
    fi

    if command -v notify-send >/dev/null 2>&1; then
        notify-send "Waybar" "No supported terminal emulator found"
    fi
    exit 127
}

target="${1:-monitor}"

case "$target" in
    monitor)
        if command -v btop >/dev/null 2>&1; then
            exec_term btop --force-utf
        elif command -v htop >/dev/null 2>&1; then
            exec_term htop
        else
            exec_term sh -lc 'top'
        fi
        ;;
    disk)
        if command -v duf >/dev/null 2>&1; then
            exec_term sh -lc 'duf; printf "\nPress Enter to close..."; read -r _'
        elif command -v ncdu >/dev/null 2>&1; then
            exec_term ncdu /
        else
            exec_term sh -lc 'df -h / "$HOME"; printf "\nPress Enter to close..."; read -r _'
        fi
        ;;
    gpu)
        if command -v nvtop >/dev/null 2>&1; then
            exec_term nvtop
        elif command -v nvidia-smi >/dev/null 2>&1; then
            exec_term sh -lc 'while :; do clear; nvidia-smi; sleep 1; done'
        else
            exec_term sh -lc 'while :; do clear; for gpu in /sys/class/drm/card*/device/gpu_busy_percent; do [ -r "$gpu" ] && printf "%s: %s%%\n" "$gpu" "$(cat "$gpu")"; done; sleep 1; done'
        fi
        ;;
    network)
        if command -v nmtui >/dev/null 2>&1; then
            exec_term nmtui
        elif command -v nm-connection-editor >/dev/null 2>&1; then
            exec nm-connection-editor
        fi
        ;;
    bluetooth)
        if command -v bluetoothctl >/dev/null 2>&1; then
            exec_term bluetoothctl
        fi
        ;;
    *)
        shift || true
        exec_term "$target" "$@"
        ;;
esac
