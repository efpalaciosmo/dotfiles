#!/usr/bin/env bash
set -euo pipefail

if command -v thunderbird >/dev/null 2>&1; then
    exec thunderbird -calendar
fi

if command -v flatpak >/dev/null 2>&1 && flatpak info org.mozilla.Thunderbird >/dev/null 2>&1; then
    exec flatpak run org.mozilla.Thunderbird -calendar
fi

if command -v gnome-calendar >/dev/null 2>&1; then
    exec gnome-calendar
fi

exit 0
