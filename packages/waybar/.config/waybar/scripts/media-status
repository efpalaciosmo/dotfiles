#!/usr/bin/env bash
set -u

json_escape() {
    local s=${1//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

if ! command -v playerctl >/dev/null 2>&1; then
    exit 1
fi

if [[ "${1:-}" == "--available" ]]; then
    playerctl metadata title >/dev/null 2>&1
    exit $?
fi

status=$(playerctl status 2>/dev/null || true)
title=$(playerctl metadata title 2>/dev/null || true)
artist=$(playerctl metadata artist 2>/dev/null || true)
album=$(playerctl metadata album 2>/dev/null || true)
player=$(playerctl metadata --format '{{playerName}}' 2>/dev/null || true)

if [[ -z "$title" ]]; then
    printf '{"text":"","tooltip":"","class":"stopped"}\n'
    exit 0
fi

case "$status" in
    Playing)
        icon=""
        class="playing"
        ;;
    Paused)
        icon=""
        class="paused"
        ;;
    *)
        icon=""
        class="stopped"
        ;;
esac

if [[ -n "$artist" ]]; then
    label="${artist} - ${title}"
else
    label="$title"
fi

tooltip="$status"
[[ -n "$player" ]] && tooltip+=" in ${player}"
tooltip+="\n${label}"
[[ -n "$album" ]] && tooltip+="\n${album}"
tooltip+="\n\nClick: play/pause\nScroll: previous/next"

printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' \
    "$(json_escape "${icon} ${label}")" \
    "$(json_escape "$tooltip")" \
    "$class"
