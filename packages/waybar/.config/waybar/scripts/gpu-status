#!/usr/bin/env bash
set -u

json_escape() {
    local s=${1//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

trim() {
    local s=$*
    s=${s#"${s%%[![:space:]]*}"}
    s=${s%"${s##*[![:space:]]}"}
    printf '%s' "$s"
}

has_sysfs_gpu() {
    local busy
    for busy in /sys/class/drm/card[0-9]/device/gpu_busy_percent; do
        [[ -r "$busy" ]] && return 0
    done
    return 1
}

if [[ "${1:-}" == "--available" ]]; then
    if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi -L >/dev/null 2>&1; then
        exit 0
    fi
    has_sysfs_gpu
    exit $?
fi

class_for_usage() {
    local usage=${1:-0}
    if (( usage >= 90 )); then
        printf 'critical'
    elif (( usage >= 75 )); then
        printf 'warning'
    else
        printf 'normal'
    fi
}

format_mib() {
    local bytes=${1:-0}
    if [[ "$bytes" =~ ^[0-9]+$ ]]; then
        printf '%s MiB' "$((bytes / 1024 / 1024))"
    fi
}

gpu_temp_c() {
    local dev=$1 input raw
    for input in "$dev"/hwmon/hwmon*/temp*_input; do
        [[ -r "$input" ]] || continue
        raw=$(<"$input")
        [[ "$raw" =~ ^[0-9]+$ ]] || continue
        (( raw >= 1000 && raw <= 125000 )) || continue
        printf '%s\n' "$(((raw + 500) / 1000))"
        return
    done
}

vendor_name() {
    local vendor_file=$1 vendor=""
    [[ -r "$vendor_file" ]] && vendor=$(<"$vendor_file")
    case "$vendor" in
        0x1002) printf 'AMD' ;;
        0x10de) printf 'NVIDIA' ;;
        0x8086) printf 'Intel' ;;
        *) printf 'GPU' ;;
    esac
}

if command -v nvidia-smi >/dev/null 2>&1; then
    line=$(nvidia-smi --query-gpu=name,utilization.gpu,temperature.gpu,memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null | head -n 1 || true)
    if [[ -n "$line" ]]; then
        IFS=',' read -r name usage temp mem_used mem_total <<< "$line"
        name=$(trim "$name")
        usage=$(trim "$usage")
        temp=$(trim "$temp")
        mem_used=$(trim "$mem_used")
        mem_total=$(trim "$mem_total")
        class=$(class_for_usage "${usage:-0}")
        text="󰢮 ${usage}%"
        tooltip="${name}\nUsage: ${usage}%\nTemperature: ${temp}°C\nVRAM: ${mem_used} / ${mem_total} MiB"
        printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' \
            "$(json_escape "$text")" \
            "$(json_escape "$tooltip")" \
            "$class"
        exit 0
    fi
fi

for busy in /sys/class/drm/card[0-9]/device/gpu_busy_percent; do
    [[ -r "$busy" ]] || continue
    dev="${busy%/gpu_busy_percent}"
    usage=$(<"$busy")
    [[ "$usage" =~ ^[0-9]+$ ]] || usage=0
    name=$(vendor_name "$dev/vendor")
    temp=$(gpu_temp_c "$dev" || true)
    class=$(class_for_usage "$usage")

    text="󰢮 ${usage}%"
    tooltip="${name} GPU\nUsage: ${usage}%"
    if [[ -n "${temp:-}" ]]; then
        tooltip+="\nTemperature: ${temp}°C"
    fi
    if [[ -r "$dev/mem_info_vram_used" && -r "$dev/mem_info_vram_total" ]]; then
        mem_used=$(format_mib "$(<"$dev/mem_info_vram_used")")
        mem_total=$(format_mib "$(<"$dev/mem_info_vram_total")")
        tooltip+="\nVRAM: ${mem_used} / ${mem_total}"
    fi

    printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' \
        "$(json_escape "$text")" \
        "$(json_escape "$tooltip")" \
        "$class"
    exit 0
done

printf '{"text":"","tooltip":"GPU utilization unavailable","class":"unavailable"}\n'
