#!/usr/bin/env bash
set -u

init_state_dir() {
    local dir
    for dir in "${XDG_RUNTIME_DIR:-}/waybar" "/tmp/waybar-${UID:-$(id -u)}"; do
        [[ -n "$dir" ]] || continue
        mkdir -p "$dir" 2>/dev/null || continue
        [[ -w "$dir" ]] || continue
        printf '%s\n' "$dir"
        return
    done
}

state_dir=$(init_state_dir)
state_file="${state_dir:+$state_dir/cpu-stat}"

json_escape() {
    local s=${1//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

read_cpu_totals() {
    local user nice system idle iowait irq softirq steal guest guest_nice
    read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    local total=$((user + nice + system + idle + iowait + irq + softirq + steal))
    local idle_all=$((idle + iowait))
    printf '%s %s\n' "$total" "$idle_all"
}

cpu_temp_c() {
    local input raw c label_file label best=""

    for input in /sys/class/hwmon/hwmon*/temp*_input /sys/class/thermal/thermal_zone*/temp; do
        [[ -r "$input" ]] || continue
        raw=$(<"$input")
        [[ "$raw" =~ ^[0-9]+$ ]] || continue
        (( raw >= 1000 && raw <= 125000 )) || continue

        c=$(((raw + 500) / 1000))
        label_file="${input%_input}_label"
        label=""
        [[ -r "$label_file" ]] && label=$(<"$label_file")

        if [[ "$label" =~ (Package|Tctl|Tdie|CPU|Core) ]]; then
            printf '%s\n' "$c"
            return
        fi

        if [[ -z "$best" || "$c" -gt "$best" ]]; then
            best="$c"
        fi
    done

    [[ -n "$best" ]] && printf '%s\n' "$best"
}

current=$(read_cpu_totals)
previous=""
[[ -n "$state_file" && -r "$state_file" ]] && previous=$(<"$state_file")

if [[ ! "$previous" =~ ^[0-9]+[[:space:]][0-9]+$ ]]; then
    previous="$current"
    sleep 0.18
    current=$(read_cpu_totals)
fi

if [[ -n "$state_file" ]]; then
    printf '%s\n' "$current" > "$state_file" 2>/dev/null || true
fi

read -r total idle <<< "$current"
read -r prev_total prev_idle <<< "$previous"

diff_total=$((total - prev_total))
diff_idle=$((idle - prev_idle))

if (( diff_total > 0 )); then
    usage=$((((diff_total - diff_idle) * 100) / diff_total))
else
    usage=0
fi

temp=$(cpu_temp_c || true)
load=$(cut -d ' ' -f 1-3 /proc/loadavg 2>/dev/null || printf 'n/a')
uptime_text=$(uptime -p 2>/dev/null | sed 's/^up //' || printf 'n/a')
top_processes=$(ps -eo comm=,pcpu= --sort=-pcpu 2>/dev/null | awk 'NF && NR <= 5 { printf "  %-18s %5.1f%%\n", $1, $2 }')

class="normal"
if (( usage >= 85 )); then
    class="critical"
elif (( usage >= 70 )); then
    class="warning"
fi

text=" ${usage}%"
if [[ -n "${temp:-}" ]]; then
    text+=" ${temp}°C"
fi

tooltip="CPU usage: ${usage}%"
if [[ -n "${temp:-}" ]]; then
    tooltip+="\nTemperature: ${temp}°C"
fi
tooltip+="\nLoad: ${load}\nUptime: ${uptime_text}"
if [[ -n "$top_processes" ]]; then
    tooltip+="\n\nTop CPU processes:\n${top_processes}"
fi

printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' \
    "$(json_escape "$text")" \
    "$(json_escape "$tooltip")" \
    "$class"
