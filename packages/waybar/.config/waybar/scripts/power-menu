#!/usr/bin/env bash
set -euo pipefail

rofi_power="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/scripts/power-menu"
if [[ -x "$rofi_power" ]]; then
    exec "$rofi_power"
fi

launcher() {
    local prompt=$1
    shift

    if command -v rofi >/dev/null 2>&1; then
        printf '%s\n' "$@" | rofi -dmenu -i -p "$prompt" \
            -theme-str 'window { width: 320px; } listview { lines: 6; } element { padding: 12px 14px; }'
    elif command -v wofi >/dev/null 2>&1; then
        printf '%s\n' "$@" | wofi --dmenu --prompt "$prompt"
    elif command -v fuzzel >/dev/null 2>&1; then
        printf '%s\n' "$@" | fuzzel --dmenu --prompt "$prompt"
    else
        return 1
    fi
}

confirm() {
    local action=$1
    local choice
    choice=$(launcher "$action?" "No" "Yes" || true)
    [[ "$choice" == "Yes" ]]
}

notify_user() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "$@" || true
    fi
}

run_systemctl() {
    local action=$1

    if systemctl -i "$action"; then
        return 0
    fi

    notify_user "Power menu" "Could not run: systemctl $action"
    return 1
}

turn_displays_off() {
    if command -v niri >/dev/null 2>&1 && niri msg action power-off-monitors; then
        return 0
    fi

    notify_user "Power menu" "Could not put displays to sleep"
    return 1
}

lock_session() {
    if command -v loginctl >/dev/null 2>&1; then
        loginctl lock-session || notify_user "Power menu" "Could not lock the session"
    fi
}

logout_session() {
    if command -v niri >/dev/null 2>&1; then
        niri msg action quit
    elif [[ -n "${XDG_SESSION_ID:-}" ]] && command -v loginctl >/dev/null 2>&1; then
        loginctl terminate-session "$XDG_SESSION_ID"
    fi
}

choice=$(launcher "Power" \
    "  Power off" \
    "  Reboot" \
    "⏾  Suspend" \
    "  Lock" \
    "  Log out" \
    "󰍹  Display sleep" || true)

case "$choice" in
    *"Power off")
        confirm "Power off" && run_systemctl poweroff
        ;;
    *"Reboot")
        confirm "Reboot" && run_systemctl reboot
        ;;
    *"Suspend")
        confirm "Suspend" && run_systemctl suspend
        ;;
    *"Lock")
        lock_session
        ;;
    *"Log out")
        confirm "Log out" && logout_session
        ;;
    *"Display sleep")
        turn_displays_off
        ;;
esac
