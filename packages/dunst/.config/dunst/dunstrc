# ~/.config/dunst/dunstrc
# Tema: Adwaita Dark (alineado con foot/niri)
#
# Paleta:
#   bg0     #1d1d20   libadwaita_dark
#   bg1     #242428   libadwaita_dark_alt
#   bg2     #36363a   libadwaita_popup
#   bg3     #4a4a4d   menu_selected
#   fg0     #ffffff   light_1
#   fg1     #deddda   light_4
#   fg2     #9a9996   light_7
#   accent  #3584e4   blue_3
#   red     #e01b24   red_3
#   orange  #ff7800   orange_3
#   green   #2ec27e   green_4
#   yellow  #e5a50a   yellow_5

[global]
    monitor = 0
    follow = mouse

    width = (300, 460)
    height = (0, 320)
    origin = top-right
    offset = 16x16
    scale = 0
    notification_limit = 6

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 180
    progress_bar_max_width = 400
    progress_bar_corner_radius = 6
    progress_bar_corners = all
    icon_corner_radius = 8
    icon_corners = all

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 16
    horizontal_padding = 18
    text_icon_padding = 14
    frame_width = 1
    frame_color = "#ff7800"
    gap_size = 10
    separator_color = frame
    sort = yes

    font = JetBrainsMono Nerd Font 12
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = end
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/Adwaita/symbolic/status/:/usr/share/icons/Adwaita/symbolic/devices/:/usr/share/icons/Adwaita/symbolic/apps/

    sticky_history = yes
    history_length = 30

    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true

    title = Dunst
    class = Dunst
    corner_radius = 12
    corners = all
    ignore_dbusclose = false

    force_xwayland = false
    force_xinerama = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#1d1d20"
    foreground = "#c0bfbc"
    frame_color = "#36363a"
    highlight = "#9a9996"
    timeout = 5
    default_icon = dialog-information-symbolic

[urgency_normal]
    background = "#1d1d20"
    foreground = "#deddda"
    frame_color = "#ff7800"
    highlight = "#ff7800"
    timeout = 8
    default_icon = dialog-information-symbolic

[urgency_critical]
    background = "#1d1d20"
    foreground = "#ffffff"
    frame_color = "#ed333b"
    highlight = "#ff7800"
    timeout = 0
    default_icon = dialog-warning-symbolic

# ---- Reglas opcionales ----

# Oculta notificaciones cuando hay una app en pantalla completa.
[fullscreen_show_critical]
    fullscreen = pushback
    msg_urgency = critical

[fullscreen_delay_everything]
    fullscreen = delay

# Player / volumen con bordes especiales.
[volume]
    appname = "volume"
    frame_color = "#2ec27e"
    highlight = "#2ec27e"

[spotify]
    appname = Spotify
    frame_color = "#2ec27e"
    highlight = "#2ec27e"
    format = "<b>%s</b>\n%b"
